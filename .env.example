# Copy this file to `.env` and adjust the values. `.env` is gitignored.

# Absolute path to your RimWorld Mods folder. `bun run deploy` (and the MSBuild
# post-build step) copies the built mod here so the game runs your fresh build.
# Windows example: C:\Steam\steamapps\common\RimWorld\Mods
# Linux example:   ~/.steam/steam/steamapps/common/RimWorld/Mods
RIMWORLD_MODS_DIR=/path/to/RimWorld/Mods

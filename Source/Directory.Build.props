<!-- Shared MSBuild properties for every project under Source/ (auto-imported by MSBuild). -->
<Project>
  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>10.0</LangVersion>
    <PlatformTarget>AnyCPU</PlatformTarget>
    <Optimize>true</Optimize>
    <DebugType>portable</DebugType>
    <Deterministic>true</Deterministic>
    <Nullable>disable</Nullable>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <!-- Synced from package.json by scripts/sync-version.ts (do not edit by hand). -->
    <Version>1.20.0</Version>
    <!-- Pinned versions, overridable from a single place. RimWorldRefVersion mirrors the game build. -->
    <RimWorldRefVersion>1.6.4518</RimWorldRefVersion>
    <HarmonyVersion>2.3.6</HarmonyVersion>
    <PublicizerVersion>2.3.0</PublicizerVersion>
  </PropertyGroup>

  <!-- net48 reference assemblies so `dotnet build` works without a Visual Studio targeting pack
       (CI runners, this dev box). PrivateAssets=all keeps them out of the shipped output. -->
  <ItemGroup>
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>
</Project>
